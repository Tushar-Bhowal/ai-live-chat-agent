# ── Server runtime ─────────────────────────────────────────────
PORT=4000
# Comma-free single origin allowed to call the API (the deployed frontend URL).
CORS_ORIGIN=http://localhost:5173

# ── LLM provider ───────────────────────────────────────────────
# Active provider: openrouter | gemini | anthropic
LLM_PROVIDER=openrouter
# OpenRouter (default). Get a key at https://openrouter.ai (no card).
OPENROUTER_API_KEY=
# Pin a specific free model (ID ends in :free); avoid the auto-router.
# Free model availability rotates — see https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Google Gemini provider. Free key (no card) at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic direct provider (reserved; not enabled).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Database ───────────────────────────────────────────────────
# Postgres connection string. Local dev example:
#   postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public
# In production, the pooled connection string.
DATABASE_URL=postgresql://livechat:CHANGEME@localhost:5432/livechat?schema=public
# Direct (non-pooled) connection string for migrations in production. Unused
# locally — the URL is read from prisma.config.ts.
DIRECT_URL=
