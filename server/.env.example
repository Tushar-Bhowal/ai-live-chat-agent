# ── Server runtime ─────────────────────────────────────────────
PORT=4000
# Comma-free single origin allowed to call the API (the deployed frontend URL).
CORS_ORIGIN=http://localhost:5173

# ── LLM provider (Phase 2) ─────────────────────────────────────
# Which provider domain/llm/index.ts selects: openrouter | anthropic
LLM_PROVIDER=openrouter
# OpenRouter (default provider). Get a key at https://openrouter.ai (no card).
OPENROUTER_API_KEY=
# Pin a specific free model (ID ends in :free) — do NOT use the auto-router.
OPENROUTER_MODEL=

# Anthropic direct provider (optional, Phase 8 only).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Database (Phase 1) ─────────────────────────────────────────
# Neon pooled connection string used by the app at runtime.
DATABASE_URL=
# Neon direct connection string used by `prisma migrate`.
DIRECT_URL=
